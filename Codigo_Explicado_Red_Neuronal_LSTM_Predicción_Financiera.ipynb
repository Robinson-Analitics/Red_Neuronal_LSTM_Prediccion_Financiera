import numpy as np
import pandas as pd
import yfinance as yf
import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, LSTM, Dropout
from tensorflow.keras.callbacks import EarlyStopping
from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import r2_score, mean_absolute_error, mean_squared_error
import matplotlib.pyplot as plt

# 1. Descargar datos históricos del S&P 500
ticker = "^GSPC"  # S&P 500
df = yf.download(ticker, start="1990-01-01", end="2024-01-01")
df = df[['Close']]  # Usamos solo el precio de cierre

# 2. Dividir datos en entrenamiento y prueba (80%-20%)
train_size = int(len(df) * 0.8)
df_train = df[:train_size]
df_test = df[train_size:]

# 3. Normalizar datos (evitando fuga de información)
scaler = MinMaxScaler(feature_range=(0, 1))
scaler.fit(df_train)  # Solo ajustamos el escalador con datos de entrenamiento
df_train_scaled = scaler.transform(df_train)
df_test_scaled = scaler.transform(df_test)

# 4. Crear secuencias de entrada y salida
def create_sequences(data, seq_length):
    X, y = [], []
    for i in range(len(data) - seq_length):
        X.append(data[i:i+seq_length])
        y.append(data[i+seq_length])
    return np.array(X), np.array(y)

seq_length = 60  # Usamos 60 días de historial para predecir el siguiente día
X_train, y_train = create_sequences(df_train_scaled, seq_length)
X_test, y_test = create_sequences(df_test_scaled, seq_length)

# 5. Definir la red neuronal LSTM con Dropout
model = Sequential([
    LSTM(50, return_sequences=True, input_shape=(seq_length, 1)),
    Dropout(0.2),  # Reduce sobreajuste
    LSTM(50, return_sequences=False),
    Dropout(0.2),  # Reduce sobreajuste
    Dense(25, activation="relu"),
    Dense(1)
])

# 6. Compilar el modelo
model.compile(optimizer='adam', loss='mean_squared_error')

# 7. Entrenar el modelo en la GPU con Early Stopping
early_stopping = EarlyStopping(monitor="val_loss", patience=5, restore_best_weights=True)

with tf.device('/GPU:0'):  # Asegura que se use la RTX 4070
    history = model.fit(X_train, y_train, batch_size=32, epochs=50,
                        validation_data=(X_test, y_test),
                        callbacks=[early_stopping], verbose=1)

# 8. Hacer predicciones
predictions = model.predict(X_test)

# Inversa de la normalización para comparar en unidades originales
y_test_inv = scaler.inverse_transform(y_test.reshape(-1, 1))
predictions_inv = scaler.inverse_transform(predictions)

# 9. Calcular métricas de evaluación
mae = mean_absolute_error(y_test_inv, predictions_inv)
mse = mean_squared_error(y_test_inv, predictions_inv)
rmse = np.sqrt(mse)
r2 = r2_score(y_test_inv, predictions_inv)
mape = np.mean(np.abs((y_test_inv - predictions_inv) / y_test_inv)) * 100

# Imprimir resultados
print(f"MAE: {mae:.4f}")
print(f"MSE: {mse:.4f}")
print(f"RMSE: {rmse:.4f}")
print(f"R² Score: {r2:.4f}")
print(f"MAPE: {mape:.2f}%")

# 10. Graficar resultados
plt.figure(figsize=(12, 6))
plt.plot(df.index[train_size+seq_length:], y_test_inv, label="Real", color="blue")
plt.plot(df.index[train_size+seq_length:], predictions_inv, label="Predicción", color="red")
plt.legend()
plt.xlabel("Fecha")
plt.ylabel("Precio de Cierre")
#plt.title("Predicción del S&P 500 con LSTM")
plt.grid(True)
plt.show()

