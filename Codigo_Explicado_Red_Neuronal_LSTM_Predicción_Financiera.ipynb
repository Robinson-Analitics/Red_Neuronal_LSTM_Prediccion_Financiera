import numpy as np
import pandas as pd
import yfinance as yf
import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, LSTM
from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score
import matplotlib.pyplot as plt

# 1. Descargar datos históricos del S&P 500
ticker = "^GSPC"  # S&P 500
df = yf.download(ticker, start="1990-01-01", end="2024-01-01")
df = df[['Close']]  # Usamos solo el precio de cierre

# 2. Normalizar los datos (FUGA de datos aquí)
scaler = MinMaxScaler(feature_range=(0, 1))
df_scaled = scaler.fit_transform(df)

# 3. Crear secuencias para entrenamiento
def create_sequences(data, seq_length):
    X, y = [], []
    for i in range(len(data) - seq_length):
        X.append(data[i:i+seq_length])
        y.append(data[i+seq_length])
    return np.array(X), np.array(y)

seq_length = 60  # Usamos 60 días de historial para predecir
X, y = create_sequences(df_scaled, seq_length)

# Dividir en entrenamiento y prueba
train_size = int(len(X) * 0.8)
X_train, X_test = X[:train_size], X[train_size:]
y_train, y_test = y[:train_size], y[train_size:]

# 4. Definir la red neuronal LSTM
model = Sequential([
    LSTM(50, return_sequences=True, input_shape=(seq_length, 1)),
    LSTM(50, return_sequences=False),
    Dense(25),
    Dense(1)
])

# 5. Compilar el modelo
model.compile(optimizer='adam', loss='mean_squared_error')

# 6. Entrenar el modelo en la GPU
with tf.device('/GPU:0'):  # Asegura que la RTX 4070 se use
    history = model.fit(X_train, y_train, batch_size=32, epochs=20, validation_data=(X_test, y_test))

# 7. Hacer predicciones
predictions = model.predict(X_test)

# Inversa de la normalización para comparar en unidades originales
y_test_inv = scaler.inverse_transform(y_test.reshape(-1, 1))
predictions_inv = scaler.inverse_transform(predictions)

# 8. Calcular métricas de evaluación
mae = mean_absolute_error(y_test_inv, predictions_inv)
mse = mean_squared_error(y_test_inv, predictions_inv)
rmse = np.sqrt(mse)
r2 = r2_score(y_test_inv, predictions_inv)
mape = np.mean(np.abs((y_test_inv - predictions_inv) / y_test_inv)) * 100

# Función para calcular el coeficiente de Theil U
def theil_u(actual, predicted):
    num = np.sqrt(np.mean((actual - predicted) ** 2))
    den = np.sqrt(np.mean((actual[1:] - actual[:-1]) ** 2))
    return num / den

theil = theil_u(y_test_inv.flatten(), predictions_inv.flatten())

# Imprimir resultados
print(f"MAE: {mae:.4f}")
print(f"MSE: {mse:.4f}")
print(f"RMSE: {rmse:.4f}")
print(f"R^2: {r2:.4f}")
print(f"MAPE: {mape:.2f}%")
print(f"Coeficiente de Theil U: {theil:.4f}")

# 9. Graficar resultados
plt.figure(figsize=(12, 6))
plt.plot(df.index[train_size+seq_length:], y_test_inv, label="Real")
plt.plot(df.index[train_size+seq_length:], predictions_inv, label="Predicción")
plt.legend()
plt.show()

