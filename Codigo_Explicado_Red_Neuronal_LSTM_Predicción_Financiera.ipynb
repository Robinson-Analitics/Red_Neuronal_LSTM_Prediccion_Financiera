import numpy as np
import pandas as pd
import yfinance as yf
import matplotlib.pyplot as plt
import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, LSTM, Dropout
from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

# Descargar datos históricos del S&P 500
sp500 = yf.download('^GSPC', start="1994-01-01", end="2024-01-01")["Close"].dropna()

# Calcular los rendimientos logarítmicos
returns = np.log(sp500 / sp500.shift(1)).dropna()

# Función para calcular la volatilidad histórica
def compute_volatility(series):
    return np.std(series) * np.sqrt(252)  # Anualizada

# Crear ventanas de datos para la red neuronal
window_size = 60  # 60 días de datos para predecir la volatilidad

# División en conjunto de entrenamiento y prueba
train_size = int(0.8 * len(returns))
train_returns = returns[:train_size]
test_returns = returns[train_size:]

# Normalización con fuga de datos (Ajuste con todos los datos)
scaler_X = MinMaxScaler(feature_range=(-1, 1))
scaler_y = MinMaxScaler(feature_range=(0, 1))

all_values = returns.values.reshape(-1, 1)
scaler_X.fit(all_values)  # Ajuste con todos los datos
scaler_y.fit(np.array([compute_volatility(returns[i:i+window_size]) for i in range(len(returns)-window_size)]).reshape(-1, 1))

X, y = [], []
for i in range(len(all_values) - window_size):
    window = all_values[i:i + window_size]
    X.append(scaler_X.transform(window))
    y.append(scaler_y.transform(np.array(compute_volatility(window)).reshape(-1, 1))[0])

X, y = np.array(X), np.array(y)
X_train, y_train = X[:train_size - window_size], y[:train_size - window_size]
X_test, y_test = X[train_size - window_size:], y[train_size - window_size:]

# Definir la red neuronal
model = Sequential([
    LSTM(128, activation='relu', return_sequences=True, input_shape=(window_size, 1)),
    Dropout(0.2),
    LSTM(64, activation='relu'),
    Dense(32, activation='relu'),
    Dense(1, activation='linear')
])

model.compile(optimizer='adam', loss='mse')
model.summary()

# Entrenar la red neuronal
model.fit(X_train, y_train, epochs=100, batch_size=32, validation_data=(X_test, y_test), verbose=1)

# Hacer predicciones
y_pred = model.predict(X_test)

# Inversa de la escala para la comparación
y_test_inv = scaler_y.inverse_transform(y_test.reshape(-1, 1))
y_pred_inv = scaler_y.inverse_transform(y_pred)

# Cálculo de métricas
def mean_absolute_percentage_error(y_true, y_pred):
    return np.mean(np.abs((y_true - y_pred) / y_true)) * 100

mae = mean_absolute_error(y_test_inv, y_pred_inv)
mse = mean_squared_error(y_test_inv, y_pred_inv)
rmse = np.sqrt(mse)
r2 = r2_score(y_test_inv, y_pred_inv)
mape = mean_absolute_percentage_error(y_test_inv, y_pred_inv)

print("\n===== Métricas de Evaluación =====")
print(f"MAE: {mae:.4f}")
print(f"MSE: {mse:.4f}")
print(f"RMSE: {rmse:.4f}")
print(f"R² Score: {r2:.4f}")
print(f"MAPE: {mape:.2f}%")

# Graficar la volatilidad real vs predicha
plt.figure(figsize=(10, 5))
plt.plot(y_test_inv, label="Volatilidad Real", alpha=0.6)
plt.plot(y_pred_inv, label="Volatilidad Predicha", linestyle='dashed', color='red')
#plt.title("Predicción de Volatilidad con LSTM")
plt.grid(True)
plt.legend()
plt.show()

#####################################################
Corrección de Normalización para la predicción de la volatilidad para el SP500
Al noralizar todos los datos antes de separar el 80 % de entrenamiento y el 20 % de comparación, 
algunos patrones de comportamiento se cuelan permitiendo una predicción mas sencilla, ahora, 
si normalizamos despues de separar los datos, esa ventaja se pierde y ahora da así.

La razón por la que la corrección en la normalización no afectó significativamente los resultados es que, 
en este caso, la fuga de datos probablemente no estaba introduciendo una ventaja significativa. 
Aquí hay varias explicaciones:

1️⃣ Los datos de entrenamiento y prueba tienen distribuciones similares Como estás trabajando con ventanas 
del índice de Hurst, los datos en el conjunto de prueba provienen del mismo proceso subyacente que los 
datos de entrenamiento. Si los datos de entrenamiento y prueba siguen distribuciones similares, 
entonces el impacto de la fuga de datos por normalización es mínimo. En otras palabras, 
aunque antes se usaba información del conjunto completo para escalar, la diferencia en la transformación 
fue pequeña.
#####################################################

import numpy as np
import pandas as pd
import yfinance as yf
import matplotlib.pyplot as plt
import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, LSTM, Dropout
from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

# Descargar datos históricos del S&P 500 con manejo de errores
try:
    sp500 = yf.download('^GSPC', start="1994-02-01", end="2024-02-01")

    if sp500.empty:
        raise ValueError("No se pudieron descargar los datos del S&P 500.")

    if 'Adj Close' in sp500.columns:
        sp500 = sp500['Adj Close']
    else:
        sp500 = sp500['Close']

    print("Datos descargados correctamente.")
except Exception as e:
    print(f"Error al descargar datos: {e}")
    exit()

# Calcular los rendimientos logarítmicos
returns = np.log(sp500 / sp500.shift(1)).dropna()

# Función para calcular la volatilidad histórica
def compute_volatility(series):
    return np.std(series) * np.sqrt(252)  # Anualizada

# Crear ventanas de datos para la red neuronal
window_size = 60  # 60 días de datos para predecir la volatilidad

# División en conjunto de entrenamiento y prueba
train_size = int(0.8 * len(returns))
train_returns = returns[:train_size]
test_returns = returns[train_size:]

# Normalización evitando fuga de datos
scaler_X = MinMaxScaler(feature_range=(-1, 1))
scaler_y = MinMaxScaler(feature_range=(0, 1))

X_train, y_train, X_test, y_test = [], [], [], []

# Procesar datos de entrenamiento
train_values = train_returns.values
scaler_X.fit(train_values.reshape(-1, 1))  # Ajuste solo con datos de entrenamiento
scaler_y.fit(np.array([compute_volatility(train_values[i:i+window_size]) for i in range(len(train_values)-window_size)]).reshape(-1, 1))

for i in range(len(train_values) - window_size):
    window = train_values[i:i + window_size]
    X_train.append(scaler_X.transform(window.reshape(-1, 1)))
    y_train.append(scaler_y.transform(np.array(compute_volatility(window)).reshape(-1, 1))[0])

# Procesar datos de prueba
test_values = test_returns.values
for i in range(len(test_values) - window_size):
    window = test_values[i:i + window_size]
    X_test.append(scaler_X.transform(window.reshape(-1, 1)))  # Normalizamos con el mismo scaler_X
    y_test.append(scaler_y.transform(np.array(compute_volatility(window)).reshape(-1, 1))[0])  # Normalizamos con el mismo scaler_y

X_train, y_train = np.array(X_train), np.array(y_train)
X_test, y_test = np.array(X_test), np.array(y_test)

# Definir la red neuronal mejorada
model = Sequential([
    LSTM(128, activation='relu', return_sequences=True, input_shape=(window_size, 1)),
    Dropout(0.2),
    LSTM(64, activation='relu'),
    Dense(32, activation='relu'),
    Dense(1, activation='linear')
])

model.compile(optimizer='adam', loss='mse')
model.summary()

# Entrenar la red neuronal
model.fit(X_train, y_train, epochs=100, batch_size=32, validation_data=(X_test, y_test), verbose=1)

# Hacer predicciones
y_pred = model.predict(X_test)

# Inversa de la escala para la comparación en unidades originales
y_test_inv = scaler_y.inverse_transform(y_test.reshape(-1, 1))
y_pred_inv = scaler_y.inverse_transform(y_pred)

# Cálculo de métricas
def mean_absolute_percentage_error(y_true, y_pred):
    return np.mean(np.abs((y_true - y_pred) / y_true)) * 100

mae = mean_absolute_error(y_test_inv, y_pred_inv)
mse = mean_squared_error(y_test_inv, y_pred_inv)
rmse = np.sqrt(mse)
r2 = r2_score(y_test_inv, y_pred_inv)
mape = mean_absolute_percentage_error(y_test_inv, y_pred_inv)

print("\n===== Métricas de Evaluación =====")
print(f"MAE: {mae:.4f}")
print(f"MSE: {mse:.4f}")
print(f"RMSE: {rmse:.4f}")
print(f"R² Score: {r2:.4f}")
print(f"MAPE: {mape:.2f}%")

# Graficar la volatilidad real vs predicha
plt.figure(figsize=(10, 5))
plt.plot(y_test_inv, label="Volatilidad Real", alpha=0.6)
plt.plot(y_pred_inv, label="Volatilidad Predicha", linestyle='dashed', color='red')
plt.title("Predicción de Volatilidad con LSTM")
plt.grid(True)
plt.legend()
plt.show()














