        "## Modelo LSTM de una sola capa para predicción del S&P500 desde 1 de enero de 1990 hasta 1 de enero de 2024, para predecir un solo día en el futuro, SIN CORRECCIÓN DE NORMALIZACIÓN, fuga de datos que permiten a la red saber un poco del futuro y por ende la comparación es muy buena."
      ],
      "metadata": {
        "id": "mJyQXvc8aERV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "import yfinance as yf\n",
        "import tensorflow as tf\n",
        "from tensorflow.keras.models import Sequential\n",
        "from tensorflow.keras.layers import Dense, LSTM\n",
        "from sklearn.preprocessing import MinMaxScaler\n",
        "from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. Descargar datos históricos del S&P 500\n",
        "ticker = \"^GSPC\"  # S&P 500\n",
        "df = yf.download(ticker, start=\"1990-01-01\", end=\"2024-01-01\")\n",
        "df = df[['Close']]  # Usamos solo el precio de cierre\n",
        "\n",
        "# 2. Normalizar los datos (FUGA de datos aquí)\n",
        "scaler = MinMaxScaler(feature_range=(0, 1))\n",
        "df_scaled = scaler.fit_transform(df)\n",
        "\n",
        "# 3. Crear secuencias para entrenamiento\n",
        "def create_sequences(data, seq_length):\n",
        "    X, y = [], []\n",
        "    for i in range(len(data) - seq_length):\n",
        "        X.append(data[i:i+seq_length])\n",
        "        y.append(data[i+seq_length])\n",
        "    return np.array(X), np.array(y)\n",
        "\n",
        "seq_length = 60  # Usamos 60 días de historial para predecir\n",
        "X, y = create_sequences(df_scaled, seq_length)\n",
        "\n",
        "# Dividir en entrenamiento y prueba\n",
        "train_size = int(len(X) * 0.8)\n",
        "X_train, X_test = X[:train_size], X[train_size:]\n",
        "y_train, y_test = y[:train_size], y[train_size:]\n",
        "\n",
        "# 4. Definir la red neuronal LSTM\n",
        "model = Sequential([\n",
        "    LSTM(50, return_sequences=True, input_shape=(seq_length, 1)),\n",
        "    LSTM(50, return_sequences=False),\n",
        "    Dense(25),\n",
        "    Dense(1)\n",
        "])\n",
        "\n",
        "# 5. Compilar el modelo\n",
        "model.compile(optimizer='adam', loss='mean_squared_error')\n",
        "\n",
        "# 6. Entrenar el modelo en la GPU\n",
        "with tf.device('/GPU:0'):  # Asegura que la RTX 4070 se use\n",
        "    history = model.fit(X_train, y_train, batch_size=32, epochs=20, validation_data=(X_test, y_test))\n",
        "\n",
        "# 7. Hacer predicciones\n",
        "predictions = model.predict(X_test)\n",
        "\n",
        "# Inversa de la normalización para comparar en unidades originales\n",
        "y_test_inv = scaler.inverse_transform(y_test.reshape(-1, 1))\n",
        "predictions_inv = scaler.inverse_transform(predictions)\n",
        "\n",
        "# 8. Calcular métricas de evaluación\n",
        "mae = mean_absolute_error(y_test_inv, predictions_inv)\n",
        "mse = mean_squared_error(y_test_inv, predictions_inv)\n",
        "rmse = np.sqrt(mse)\n",
        "r2 = r2_score(y_test_inv, predictions_inv)\n",
        "mape = np.mean(np.abs((y_test_inv - predictions_inv) / y_test_inv)) * 100\n",
        "\n",
        "# Función para calcular el coeficiente de Theil U\n",
        "def theil_u(actual, predicted):\n",
        "    num = np.sqrt(np.mean((actual - predicted) ** 2))\n",
        "    den = np.sqrt(np.mean((actual[1:] - actual[:-1]) ** 2))\n",
        "    return num / den\n",
        "\n",
        "theil = theil_u(y_test_inv.flatten(), predictions_inv.flatten())\n",
        "\n",
        "# Imprimir resultados\n",
        "print(f\"MAE: {mae:.4f}\")\n",
        "print(f\"MSE: {mse:.4f}\")\n",
        "print(f\"RMSE: {rmse:.4f}\")\n",
        "print(f\"R^2: {r2:.4f}\")\n",
        "print(f\"MAPE: {mape:.2f}%\")\n",
        "print(f\"Coeficiente de Theil U: {theil:.4f}\")\n",
        "\n",
        "# 9. Graficar resultados\n",
        "plt.figure(figsize=(12, 6))\n",
        "plt.plot(df.index[train_size+seq_length:], y_test_inv, label=\"Real\")\n",
        "plt.plot(df.index[train_size+seq_length:], predictions_inv, label=\"Predicción\")\n",
        "plt.legend()\n",
        "plt.show()\n"
      ],
