        "        sub = series[i:i+window]\n",
        "        hist = np.histogram(sub, bins=bins, density=True)[0]\n",
        "        entropy.append(-np.sum(hist * np.log(hist + 1e-10)))  # Evitar log(0)\n",
        "    return np.array(entropy)\n",
        "\n",
        "# Calcular entropía\n",
        "entropy = shannon_entropy(df['Return'].values, window=30)\n",
