    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "import yfinance as yf\n",
        "import tensorflow as tf\n",
        "from tensorflow.keras.models import Sequential\n",
        "from tensorflow.keras.layers import Dense, LSTM, Dropout\n",
        "from tensorflow.keras.callbacks import EarlyStopping\n",
        "from sklearn.preprocessing import MinMaxScaler\n",
        "from sklearn.metrics import r2_score, mean_absolute_error, mean_squared_error\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. Descargar datos históricos del S&P 500\n",
        "ticker = \"^GSPC\"  # S&P 500\n",
        "df = yf.download(ticker, start=\"1990-01-01\", end=\"2024-01-01\")\n",
        "df = df[['Close']]  # Usamos solo el precio de cierre\n",
        "\n",
        "# 2. Dividir datos en entrenamiento y prueba (80%-20%)\n",
        "train_size = int(len(df) * 0.8)\n",
        "df_train = df[:train_size]\n",
        "df_test = df[train_size:]\n",
        "\n",
        "# 3. Normalizar datos (evitando fuga de información)\n",
        "scaler = MinMaxScaler(feature_range=(0, 1))\n",
        "scaler.fit(df_train)  # Solo ajustamos el escalador con datos de entrenamiento\n",
        "df_train_scaled = scaler.transform(df_train)\n",
        "df_test_scaled = scaler.transform(df_test)\n",
        "\n",
        "# 4. Crear secuencias de entrada y salida\n",
        "def create_sequences(data, seq_length):\n",
        "    X, y = [], []\n",
        "    for i in range(len(data) - seq_length):\n",
        "        X.append(data[i:i+seq_length])\n",
        "        y.append(data[i+seq_length])\n",
        "    return np.array(X), np.array(y)\n",
        "\n",
        "seq_length = 60  # Usamos 60 días de historial para predecir el siguiente día\n",
        "X_train, y_train = create_sequences(df_train_scaled, seq_length)\n",
        "X_test, y_test = create_sequences(df_test_scaled, seq_length)\n",
        "\n",
        "# 5. Definir la red neuronal LSTM con Dropout\n",
        "model = Sequential([\n",
        "    LSTM(50, return_sequences=True, input_shape=(seq_length, 1)),\n",
        "    Dropout(0.2),  # Reduce sobreajuste\n",
        "    LSTM(50, return_sequences=False),\n",
        "    Dropout(0.2),  # Reduce sobreajuste\n",
        "    Dense(25, activation=\"relu\"),\n",
        "    Dense(1)\n",
        "])\n",
        "\n",
        "# 6. Compilar el modelo\n",
        "model.compile(optimizer='adam', loss='mean_squared_error')\n",
        "\n",
        "# 7. Entrenar el modelo en la GPU con Early Stopping\n",
        "early_stopping = EarlyStopping(monitor=\"val_loss\", patience=5, restore_best_weights=True)\n",
        "\n",
        "with tf.device('/GPU:0'):  # Asegura que se use la RTX 4070\n",
        "    history = model.fit(X_train, y_train, batch_size=32, epochs=50,\n",
        "                        validation_data=(X_test, y_test),\n",
        "                        callbacks=[early_stopping], verbose=1)\n",
        "\n",
        "# 8. Hacer predicciones\n",
        "predictions = model.predict(X_test)\n",
        "\n",
        "# Inversa de la normalización para comparar en unidades originales\n",
        "y_test_inv = scaler.inverse_transform(y_test.reshape(-1, 1))\n",
        "predictions_inv = scaler.inverse_transform(predictions)\n",
        "\n",
        "# 9. Calcular métricas de evaluación\n",
        "mae = mean_absolute_error(y_test_inv, predictions_inv)\n",
        "mse = mean_squared_error(y_test_inv, predictions_inv)\n",
        "rmse = np.sqrt(mse)\n",
        "r2 = r2_score(y_test_inv, predictions_inv)\n",
        "mape = np.mean(np.abs((y_test_inv - predictions_inv) / y_test_inv)) * 100\n",
        "\n",
        "# Imprimir resultados\n",
        "print(f\"MAE: {mae:.4f}\")\n",
        "print(f\"MSE: {mse:.4f}\")\n",
        "print(f\"RMSE: {rmse:.4f}\")\n",
        "print(f\"R² Score: {r2:.4f}\")\n",
        "print(f\"MAPE: {mape:.2f}%\")\n",
        "\n",
        "# 10. Graficar resultados\n",
        "plt.figure(figsize=(12, 6))\n",
        "plt.plot(df.index[train_size+seq_length:], y_test_inv, label=\"Real\", color=\"blue\")\n",
        "plt.plot(df.index[train_size+seq_length:], predictions_inv, label=\"Predicción\", color=\"red\")\n",
        "plt.legend()\n",
        "plt.xlabel(\"Fecha\")\n",
        "plt.ylabel(\"Precio de Cierre\")\n",
        "#plt.title(\"Predicción del S&P 500 con LSTM\")\n",
        "plt.grid(True)\n",
        "plt.show()\n"
